    conn = WREGISConnector()

    # --- Path 1: Public generators report ---
    generators = conn.fetch_public_generators(
        state_filter="OR",
        cache_path=Path("wregis_generators_cache.xlsx"),  # avoids re-downloading
    )

    # --- Path 2: Your account export CSV ---
    # Download from WREGIS > Reports > Certificate Reports > Export to CSV
