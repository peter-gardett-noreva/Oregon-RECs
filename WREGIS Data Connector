    certs = conn.parse_certificate_export(
        path_or_content="wregis_certificate_export.csv",
        oregon_only=True,
        status_filter=["Active", "Retired"],
    )

    conn.summary(generators, certs)

    # --- Bridge to assessor ---
    rec_records = conn.to_rec_records(certs, generators)
    print(f"\nConverted {len(rec_records)} records ready for OregonRECPriceAssessor")
